generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  educator
  student
  admin
}

enum PublicationStatus {
  draft
  published
}

enum QuizType {
  pre
  post
}

enum CourseAttemptStatus {
  not_started
  in_progress
  completed
  failed
}

enum CourseArea {
  environmental
  social
  governance
  cross_cutting
}

enum CourseDifficulty {
  foundation
  intermediate
}

// Models
model Profile {
  id                 String              @id
  email              String              @unique
  fullName           String?
  role               UserRole            @default(student)
  preferredLanguage  String              @default("en")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  userCourseAttempts UserCourseAttempt[]
}

model Course {
  id                       String              @id @default(cuid())
  slug                     String              @unique
  status                   PublicationStatus   @default(draft)
  area                     CourseArea
  difficulty               CourseDifficulty    @default(foundation)
  estimatedDurationMinutes Int?
  lessonsCount             Int                 @default(0)
  sortOrder                Int                 @default(0)
  isFeatured               Boolean             @default(false)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  translations             CourseTranslation[]
  quizzes                  Quiz[]
  userCourseAttempts       UserCourseAttempt[]

  @@index([status])
  @@index([area])
  @@index([difficulty])
  @@index([sortOrder])
  @@index([isFeatured])
}

model CourseTranslation {
  id          String   @id @default(cuid())
  courseId    String
  language    String
  title       String
  subtitle    String?
  description String?
  content     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, language])
  @@index([language])
  @@index([courseId])
}

model Quiz {
  id           String   @id @default(cuid())
  courseId     String
  type         QuizType
  title        String?
  description  String?
  passingScore Int?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]

  @@unique([courseId, type])
  @@index([courseId])
}

model Question {
  id          String   @id @default(cuid())
  quizId      String
  prompt      String
  explanation String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([quizId])
}

model Answer {
  id           String   @id @default(cuid())
  questionId   String
  text         String
  isCorrect    Boolean  @default(false)
  feedbackText String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model UserCourseAttempt {
  id              String              @id @default(cuid())
  userId          String
  courseId        String
  status          CourseAttemptStatus @default(not_started)
  progressPercent Int                 @default(0)
  preQuizScore    Int?
  postQuizScore   Int?
  startedAt       DateTime?
  lastOpenedAt    DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}
